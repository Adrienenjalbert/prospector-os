│   │   ├── scoring/                        # 7 scorers + composite + tier matcher + calibration analyzer
│   │   ├── funnel/                         # Benchmark, stall, impact, forecast
│   │   ├── prioritisation/                 # Queues, actions, briefings
│   │   ├── notifications/                  # Triggers, cooldowns, feedback
│   │   ├── citations/                      # Source tracking engine
│   │   ├── telemetry/                      # emitAgentEvent / emitOutcomeEvent
│   │   └── types/                          # Ontology, URN, Zod schemas, config
│   ├── adapters/
│   │   ├── crm/                            # HubSpot + Salesforce
│   │   ├── enrichment/                     # Apollo
│   │   ├── connectors/                     # Universal connector interface + transcript
│   │   ├── notifications/                  # Slack dispatcher + cooldown store + web push
│   │   └── transcripts/                    # Gong + Fireflies ingester
│   └── db/
│       ├── migrations/                     # 001 platform, 002 events + foundation
│       └── schema/                         # Baseline schema.sql
└── scripts/                                # seed-tools, setup
